# AI Providers
GEMINI_API_KEY=
SARVAM_API_KEY=
OPENAI_API_KEY=

# Model selection (optional — defaults will be used if omitted)
GEMINI_FAST_MODEL=gemini-2.0-flash
GEMINI_POWER_MODEL=gemini-2.5-pro

# Database
# For production, use a Postgres connection string (e.g., Vercel Postgres or Supabase)
DATABASE_URL=

# Storage (Vercel Blob)
# Generated in Vercel Dashboard > Storage > Blob
BLOB_READ_WRITE_TOKEN=

# Background Jobs (Inngest)
# Get these from your Inngest Cloud dashboard
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Auth (NextAuth)
# Generate a secret via: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google SSO (Recruiter Login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin & Monitoring
ADMIN_API_TOKEN=

# Legacy Object Storage (Optional fallback)
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
